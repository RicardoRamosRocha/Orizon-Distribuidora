@{
    ViewData["Title"] = "Dashboard";
    ViewData["ApplicationName"] = "Distribuidora";
}

<header class="orizon-page-header">
    <div>
        <h1 class="orizon-page-title">Dashboard</h1>

        <p class="orizon-page-description">
            Visão geral da operação da distribuidora.
        </p>
    </div>

    <orizon-button variant="primary"
                   icon="plus">
        Novo produto
    </orizon-button>
</header>

<section class="orizon-dashboard-grid"
         aria-label="Indicadores principais">

    <orizon-card>
        <div class="orizon-stat-card">
            <span class="orizon-stat-label">
                Produtos cadastrados
            </span>

            <strong class="orizon-stat-value">
                0
            </strong>

            <span class="orizon-stat-description">
                Produtos próprios e intermediados
            </span>
        </div>
    </orizon-card>

    <orizon-card>
        <div class="orizon-stat-card">
            <span class="orizon-stat-label">
                Estoque físico
            </span>

            <strong class="orizon-stat-value">
                0
            </strong>

            <span class="orizon-stat-description">
                Itens disponíveis
            </span>
        </div>
    </orizon-card>

    <orizon-card>
        <div class="orizon-stat-card">
            <span class="orizon-stat-label">
                Estoque baixo
            </span>

            <strong class="orizon-stat-value">
                0
            </strong>

            <span class="orizon-stat-description">
                Produtos que exigem atenção
            </span>
        </div>
    </orizon-card>

    <orizon-card>
        <div class="orizon-stat-card">
            <span class="orizon-stat-label">
                Vendas do mês
            </span>

            <strong class="orizon-stat-value">
                R$ 0,00
            </strong>

            <span class="orizon-stat-description">
                Nenhuma venda registrada
            </span>
        </div>
    </orizon-card>

</section>

<section style="margin-top: 1.5rem;">
    <orizon-card title="Fundação do sistema">
        <orizon-alert variant="success"
                      title="Orizon UI integrado">
            A aplicação está usando o layout administrativo e os componentes
            compartilhados do ecossistema Orizon.
        </orizon-alert>
    </orizon-card>
</section>

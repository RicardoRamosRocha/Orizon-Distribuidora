@{
    ViewData["Title"] = "Configurações";
}

<div class="orizon-page">

    <div class="orizon-page-header">

        <div>
            <h1>Configurações</h1>

            <p>
                Gerencie as configurações gerais da plataforma Orizon Distribuidora.
            </p>
        </div>

        <div>

            <orizon-button icon="save"
                            color="primary">
                Salvar Alterações
            </orizon-button>

        </div>

    </div>

    <div class="orizon-dashboard-grid">

        <orizon-card>

            <orizon-card-header>

                <orizon-icon name="building"></orizon-icon>

                <span>Empresa</span>

            </orizon-card-header>

            <orizon-card-body>

                <p>
                    Dados cadastrais, CNPJ, endereço, contatos e identidade visual.
                </p>

                <orizon-button asp-controller="Company"
                                asp-action="Index"
                                variant="outline">
                    Abrir
                </orizon-button>

            </orizon-card-body>

        </orizon-card>

        <orizon-card>

            <orizon-card-header>

                <orizon-icon name="users"></orizon-icon>

                <span>Usuários</span>

            </orizon-card-header>

            <orizon-card-body>

                <p>
                    Administração de usuários, perfis e permissões.
                </p>

                <orizon-button asp-controller="Users"
                                asp-action="Index"
                                variant="outline">
                    Abrir
                </orizon-button>

            </orizon-card-body>

        </orizon-card>

        <orizon-card>

            <orizon-card-header>

                <orizon-icon name="database"></orizon-icon>

                <span>Banco de Dados</span>

            </orizon-card-header>

            <orizon-card-body>

                <p>
                    Backup, restauração e manutenção.
                </p>

                <orizon-button variant="outline">

                    Backup

                </orizon-button>

            </orizon-card-body>

        </orizon-card>

        <orizon-card>

            <orizon-card-header>

                <orizon-icon name="shield"></orizon-icon>

                <span>Segurança</span>

            </orizon-card-header>

            <orizon-card-body>

                <p>

                    Senhas, autenticação e auditoria.

                </p>

                <orizon-button variant="outline">

                    Configurar

                </orizon-button>

            </orizon-card-body>

        </orizon-card>

        <orizon-card>

            <orizon-card-header>

                <orizon-icon name="gear"></orizon-icon>

                <span>Sistema</span>

            </orizon-card-header>

            <orizon-card-body>

                <p>

                    Parâmetros gerais do sistema.

                </p>

                <orizon-button variant="outline">

                    Abrir

                </orizon-button>

            </orizon-card-body>

        </orizon-card>

        <orizon-card>

            <orizon-card-header>

                <orizon-icon name="cloud"></orizon-icon>

                <span>Integrações</span>

            </orizon-card-header>

            <orizon-card-body>

                <p>

                    APIs, WhatsApp, e-mail e serviços externos.

                </p>

                <orizon-button variant="outline">

                    Configurar

                </orizon-button>

            </orizon-card-body>

        </orizon-card>

    </div>

</div>
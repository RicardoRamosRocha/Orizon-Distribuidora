@model HistoricoImportacaoDetalhesViewModel
@{ViewData["Title"]="Detalhes da importação";ViewData["ApplicationName"]="Distribuidora";var i=Model.Detalhes.Importacao;}
<header class="orizon-page-header"><div><h1 class="orizon-page-title">@i.Arquivo</h1><p class="orizon-page-description">Consulta somente leitura dos dados persistidos da importação.</p></div><a class="btn btn-primary" href="@Url.Action("Resultado",new{id=i.Id})">Abrir resultado completo</a></header>
<orizon-card title="Resumo"><dl style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem"><div><dt>Código</dt><dd>@i.Id</dd></div><div><dt>Usuário</dt><dd>@i.Usuario</dd></div><div><dt>Status</dt><dd>@i.Status</dd></div><div><dt>Modelo</dt><dd>@(i.Modelo??"—")</dd></div><div><dt>Total</dt><dd>@i.TotalLinhas</dd></div><div><dt>Inseridos</dt><dd>@i.Inseridos</dd></div><div><dt>Atualizados</dt><dd>@i.Atualizados</dd></div><div><dt>Falhas</dt><dd>@i.Falhas</dd></div></dl></orizon-card>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem"><orizon-card title="Erros recorrentes"><ul>@foreach(var e in Model.Detalhes.ResumoErros){<li>@e</li>}</ul></orizon-card><orizon-card title="Avisos recorrentes"><ul>@foreach(var a in Model.Detalhes.ResumoAvisos){<li>@a</li>}</ul></orizon-card></div>
<div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:1rem"><a class="btn btn-secondary" href="@Url.Action("Historico")">Voltar</a><a class="btn btn-secondary" href="@Url.Action("ExportarExcel",new{id=i.Id})">Excel</a><a class="btn btn-secondary" href="@Url.Action("ExportarCsv",new{id=i.Id})">CSV</a></div>

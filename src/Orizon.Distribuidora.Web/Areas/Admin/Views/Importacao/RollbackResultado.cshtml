@model RollbackResultadoViewModel
@{ViewData["Title"]="Resultado do rollback";ViewData["ApplicationName"]="Distribuidora";var r=Model.Resultado;}
<header class="orizon-page-header"><div><h1 class="orizon-page-title">Resultado do rollback</h1><p class="orizon-page-description">Status: @r.Status · duração @r.Duracao.TotalSeconds.ToString("0.0")s</p></div></header>
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1rem"><orizon-card title="Removidos"><strong style="font-size:2rem">@r.ProdutosRemovidos</strong></orizon-card><orizon-card title="Restaurados"><strong style="font-size:2rem">@r.ProdutosRestaurados</strong></orizon-card><orizon-card title="Bloqueados"><strong style="font-size:2rem">@r.ProdutosBloqueados</strong></orizon-card><orizon-card title="Falhas"><strong style="font-size:2rem">@r.Falhas</strong></orizon-card></div>
<orizon-card title="Itens"><div style="overflow:auto"><table class="table"><thead><tr><th>Linha</th><th>Produto</th><th>Operação</th><th>Revertido</th><th>Mensagem</th></tr></thead><tbody>@foreach(var i in r.Itens){<tr><td>@i.Linha</td><td>@i.ProdutoId</td><td>@i.Operacao</td><td>@(i.Revertido?"Sim":"Não")</td><td>@i.Mensagem</td></tr>}</tbody></table></div></orizon-card>
<div style="display:flex;justify-content:flex-end;gap:.75rem;margin-top:1rem"><a class="btn btn-secondary" href="@Url.Action("Historico")">Histórico</a><a class="btn btn-secondary" href="@Url.Action("RollbackExcel",new{id=r.ImportacaoId})">Excel</a><a class="btn btn-secondary" href="@Url.Action("RollbackCsv",new{id=r.ImportacaoId})">CSV</a></div>

@model ImportacaoValidacaoViewModel
@using System.Text.Json
@{ViewData["Title"]="Validação da importação";ViewData["ApplicationName"]="Distribuidora";}
@section Styles{<style>.validation-meta,.validation-cards{display:grid;gap:1rem}.validation-meta{grid-template-columns:repeat(4,1fr)}.validation-cards{grid-template-columns:repeat(8,1fr);margin:1rem 0}.v-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:1rem}.v-card b{display:block;font-size:1.5rem}.v-card.error{border-color:#fecaca;background:#fff7f7}.v-card.warn{border-color:#fde68a;background:#fffbeb}.filters{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center}.filters button,.filter-link{border:1px solid #cbd5e1;border-radius:999px;background:#fff;padding:.45rem .7rem}.filter-link.active{background:#1d4ed8;color:#fff}.status-pill{display:inline-flex;border-radius:99px;padding:.25rem .5rem;background:#e2e8f0;font-size:.75rem}.status-pill.ok{background:#dcfce7;color:#166534}.status-pill.error{background:#fee2e2;color:#991b1b}.pagination{display:flex;justify-content:center;gap:1rem;align-items:center;margin-top:1rem}.details{max-width:760px}.details pre{white-space:pre-wrap;max-height:260px;overflow:auto;background:#f8fafc;padding:.7rem;border-radius:8px}@@media(max-width:1100px){.validation-cards{grid-template-columns:repeat(4,1fr)}.validation-meta{grid-template-columns:1fr 1fr}}@@media(max-width:600px){.validation-cards,.validation-meta{grid-template-columns:1fr 1fr}}</style>}
<header class="orizon-page-header"><div><h1 class="orizon-page-title">Validação dos dados</h1><p class="orizon-page-description">Resultado da análise completa antes de qualquer gravação definitiva.</p></div><span class="status-pill @(Model.Resultado.PodeImportar?"ok":"error")">@(Model.Resultado.PodeImportar?"Pronta para avançar":"Requer correções")</span></header>
<orizon-card title="Execução"><div class="validation-meta"><div><small>Arquivo</small><strong>@Model.NomeArquivo</strong></div><div><small>Planilha</small><strong>@Model.AbaSelecionada</strong></div><div><small>Validado em</small><strong>@Model.Resultado.ValidadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong></div><div><small>Status</small><strong>@(Model.Resultado.PodeImportar?"Validação concluída":"Validação com erros")</strong></div></div></orizon-card>
<div class="validation-cards"><div class="v-card"><span>Analisadas</span><b>@Model.Resultado.TotalLinhas</b></div><div class="v-card"><span>Válidas</span><b>@Model.Resultado.QuantidadeValida</b></div><div class="v-card"><span>Novos</span><b>@Model.Resultado.QuantidadeNovos</b></div><div class="v-card"><span>Atualizações</span><b>@Model.Resultado.QuantidadeAtualizaveis</b></div><div class="v-card warn"><span>Avisos</span><b>@Model.Resultado.QuantidadeComAviso</b></div><div class="v-card error"><span>Erros</span><b>@Model.Resultado.QuantidadeComErro</b></div><div class="v-card error"><span>Duplicadas</span><b>@Model.Resultado.QuantidadeDuplicidades</b></div><div class="v-card"><span>Ignoradas</span><b>@Model.Resultado.QuantidadeIgnoradas</b></div></div>
<orizon-card title="Linhas da planilha"><form method="post" asp-action="Validacao" id="filterForm">@Html.AntiForgeryToken()<input type="hidden" asp-for="Request.ImportacaoId" name="ImportacaoId"><input type="hidden" asp-for="Request.TokenArquivo" name="TokenArquivo"><input type="hidden" asp-for="Request.AbaSelecionada" name="AbaSelecionada"><input type="hidden" asp-for="Request.MapeamentoJson" name="MapeamentoJson"><input type="hidden" asp-for="Request.InserirNovos" name="InserirNovos"><input type="hidden" asp-for="Request.AtualizarExistentes" name="AtualizarExistentes"><input type="hidden" asp-for="Request.IgnorarVaziosAtualizacao" name="IgnorarVaziosAtualizacao"><input type="hidden" asp-for="Request.PermitirImportacaoParcial" name="PermitirImportacaoParcial"><input type="hidden" asp-for="Request.BloquearComQualquerErro" name="BloquearComQualquerErro"><input type="hidden" name="Pagina" id="page" value="1"><div class="filters">@foreach(var f in new[]{("","Todas"),("validas","Válidas"),("novas","Novas"),("atualizacoes","Atualizações"),("avisos","Avisos"),("erros","Erros"),("duplicadas","Duplicadas"),("ignoradas","Ignoradas")}){<button name="Filtro" value="@f.Item1" class="filter-link @(Model.Filtro==f.Item1?"active":"")">@f.Item2</button>}<input class="form-control" style="max-width:300px" name="Busca" value="@Model.Busca" placeholder="Código, descrição, linha ou erro"><button>Buscar</button></div></form><div style="overflow:auto;margin-top:1rem"><table class="table"><thead><tr><th>Linha</th><th>Código</th><th>Descrição</th><th>Operação</th><th>Status</th><th>Erros</th><th>Avisos</th><th></th></tr></thead><tbody>@foreach(var l in Model.Linhas){<tr><td>@l.NumeroLinha</td><td>@l.CodigoProduto</td><td>@l.Descricao</td><td>@l.Operacao</td><td><span class="status-pill @(l.PodeImportar?"ok":"error")">@l.Status</span></td><td>@l.Erros.Count</td><td>@l.Avisos.Count</td><td><button type="button" class="btn btn-secondary detail-button" data-id="detail-@l.NumeroLinha">Detalhes</button><dialog class="details" id="detail-@l.NumeroLinha"><h3>Linha @l.NumeroLinha</h3>@if(l.ProdutoExistente is not null){<p>Produto existente: <strong>@l.ProdutoExistente.Codigo — @l.ProdutoExistente.Descricao</strong></p>}<h4>Erros e avisos</h4><ul>@foreach(var e in l.Erros.Concat(l.Avisos)){<li><strong>@e.Codigo:</strong> @e.Mensagem</li>}</ul><h4>Alterações propostas</h4><ul>@foreach(var a in l.Alteracoes){<li>@a.Campo: <code>@a.ValorAtual</code> → <code>@a.ValorConvertido</code></li>}</ul><h4>Dados originais</h4><pre>@JsonSerializer.Serialize(l.DadosOriginais,new JsonSerializerOptions{WriteIndented=true})</pre><form method="dialog"><button class="btn btn-secondary">Fechar</button></form></dialog></td></tr>}</tbody></table></div><div class="pagination"><button class="btn btn-secondary page-btn" data-page="@(Model.Pagina-1)" disabled="@(Model.Pagina<=1)">← Anterior</button><span>Página @Model.Pagina de @Model.TotalPaginas</span><button class="btn btn-secondary page-btn" data-page="@(Model.Pagina+1)" disabled="@(Model.Pagina>=Model.TotalPaginas)">Próxima →</button></div></orizon-card>
<form method="post" asp-action="Executar" style="display:flex;justify-content:flex-end;margin-top:1rem" onsubmit="return confirm('Executar a importação? Novos: @Model.Resultado.QuantidadeNovos | Atualizações: @Model.Resultado.QuantidadeAtualizaveis | Ignoradas/bloqueadas: @(Model.Resultado.QuantidadeIgnoradas+Model.Resultado.QuantidadeComErro). Importação parcial: @(Model.Request.PermitirImportacaoParcial?"ativa":"desativada").')">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.ImportacaoId"><button class="btn btn-primary" disabled="@(!Model.Resultado.PodeImportar)">Importar linhas válidas</button></form>
<script>const persist=document.createElement('input');persist.type='hidden';persist.name='PersistirResultado';persist.value='false';document.querySelector('#filterForm').appendChild(persist);document.querySelectorAll('.detail-button').forEach(x=>x.onclick=()=>document.querySelector('#'+x.dataset.id).showModal());document.querySelectorAll('.page-btn').forEach(x=>x.onclick=()=>{document.querySelector('#page').value=x.dataset.page;document.querySelector('#filterForm').submit()});</script>

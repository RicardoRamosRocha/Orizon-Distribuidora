@model RollbackConfirmacaoViewModel
@{ViewData["Title"]="Rollback controlado";ViewData["ApplicationName"]="Distribuidora";var a=Model.Analise;}
<header class="orizon-page-header"><div><h1 class="orizon-page-title">Rollback controlado</h1><p class="orizon-page-description">Revise os riscos antes de autorizar uma operação destrutiva.</p></div></header>
@if(TempData["Error"] is string error){<div class="alert alert-danger">@error</div>}
<orizon-card title="Análise de segurança"><div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem"><div><span>Produtos criados</span><strong style="display:block;font-size:1.5rem">@a.ProdutosCriados</strong></div><div><span>Produtos alterados</span><strong style="display:block;font-size:1.5rem">@a.ProdutosAlterados</strong></div><div><span>Bloqueados</span><strong style="display:block;font-size:1.5rem">@a.ProdutosBloqueados</strong></div><div><span>Tempo estimado</span><strong style="display:block;font-size:1.5rem">@a.TempoEstimado.TotalSeconds.ToString("0.0")s</strong></div></div><h3>Riscos e proteções</h3><ul>@foreach(var r in a.Riscos){<li>@r</li>}</ul></orizon-card>
<orizon-card title="Confirmação explícita"><form method="post" asp-action="ExecutarRollback" asp-route-id="@a.ImportacaoId">@Html.AntiForgeryToken()<label><input type="checkbox" name="permitirParcial" value="true"> Permitir rollback parcial dos produtos seguros</label><p>Digite <strong>CONFIRMAR</strong> para continuar:</p><input class="form-control" name="confirmacao" autocomplete="off" required pattern="CONFIRMAR"><div style="display:flex;justify-content:flex-end;gap:.75rem;margin-top:1rem"><a class="btn btn-secondary" href="@Url.Action("Historico")">Cancelar</a><button class="btn btn-danger" disabled="@(!a.Permitido)">Executar rollback</button></div></form></orizon-card>

@model ImportacaoMapeamentoViewModel
@using System.Text.Json
@{ ViewData["Title"] = "Mapeamento de colunas"; ViewData["ApplicationName"] = "Distribuidora"; }
@section Styles { <style>
.map-hero,.map-stats{display:grid;gap:1rem}.map-hero{grid-template-columns:1fr auto;align-items:center}.map-stats{grid-template-columns:repeat(4,1fr);margin:1rem 0}.map-stat{padding:1rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff}.map-stat b{display:block;font-size:1.5rem}.map-progress{height:9px;background:#e2e8f0;border-radius:99px;overflow:hidden}.map-progress i{display:block;height:100%;background:linear-gradient(90deg,#2563eb,#10b981);transition:width .2s}.map-grid{width:100%;border-collapse:separate;border-spacing:0}.map-grid th,.map-grid td{padding:.8rem;border-bottom:1px solid #e2e8f0;text-align:left}.map-grid select,.model-input{width:100%;padding:.6rem;border:1px solid #cbd5e1;border-radius:8px;background:#fff}.map-row.error{background:#fff7f7}.map-row.required .field-name:after{content:' Obrigatório';font-size:.7rem;color:#b91c1c;background:#fee2e2;border-radius:99px;padding:.2rem .45rem;margin-left:.4rem}.badge{display:inline-flex;padding:.25rem .5rem;border-radius:99px;font-size:.75rem;background:#e2e8f0}.badge.ok{background:#dcfce7;color:#166534}.badge.warn{background:#fef3c7;color:#92400e}.preview-wrap{overflow:auto;max-height:520px}.preview-table{white-space:nowrap}.preview-table .empty{background:#fee2e2;color:#991b1b}.preview-table th small{display:block;color:#64748b}.map-actions{display:flex;justify-content:space-between;gap:1rem;margin-top:1rem;flex-wrap:wrap}.model-bar{display:grid;grid-template-columns:1fr auto auto auto;gap:.6rem;align-items:end}.notice{padding:.7rem 1rem;border-radius:8px;background:#eff6ff;color:#1e40af;margin:.8rem 0}.notice.error{background:#fee2e2;color:#991b1b}@@media(max-width:900px){.map-stats{grid-template-columns:1fr 1fr}.map-hero,.model-bar{grid-template-columns:1fr}.map-grid{min-width:900px}}
</style> }
<header class="orizon-page-header"><div><h1 class="orizon-page-title">Mapeamento inteligente</h1><p class="orizon-page-description">Associe os campos do cadastro às colunas de <strong>@Model.NomeArquivo</strong>. A prévia responde imediatamente às alterações.</p></div><span class="badge">Etapa 3 de 6</span></header>
@Html.AntiForgeryToken()
<orizon-card title="Modelo de importação">
 <div class="model-bar"><label>Modelo<select id="modelSelect" class="model-input"><option value="">Mapeamento automático</option>@foreach(var m in Model.Modelos){<option value="@m.Id" selected="@(m.Id==Model.ModeloCarregadoId)">@m.Nome @(m.Padrao ? "• Padrão" : "")</option>}</select></label><button type="button" class="btn btn-secondary" id="saveModel">Salvar modelo</button><button type="button" class="btn btn-secondary" id="deleteModel" @(Model.ModeloCarregadoId is null ? "disabled" : null)>Excluir</button></div>
 @if(Model.ModeloCarregadoId is not null){<div class="notice">Modelo compatível reconhecido e carregado automaticamente.</div>}
</orizon-card>
<div class="map-stats"><div class="map-stat"><span>Progresso</span><b id="progressText">0%</b><div class="map-progress"><i id="progressBar"></i></div></div><div class="map-stat"><span>Campos mapeados</span><b id="mappedCount">0</b></div><div class="map-stat"><span>Colunas não utilizadas</span><b id="unusedCount">0</b></div><div class="map-stat"><span>Obrigatórios faltando</span><b id="missingCount">0</b></div></div>
<orizon-card title="Associe as colunas"><div id="validationNotice" class="notice" hidden></div><div style="overflow:auto"><table class="map-grid"><thead><tr><th>Campo do sistema</th><th>Coluna da planilha</th><th>Status</th><th>Tipo</th><th>Observação</th></tr></thead><tbody>
@foreach(var campo in Model.Campos){ Model.Mapeamentos.TryGetValue(campo.Chave,out var selected); Model.Confiancas.TryGetValue(campo.Chave,out var confidence);<tr class="map-row @(campo.Obrigatorio?"required":"")" data-field="@campo.Chave" data-required="@campo.Obrigatorio.ToString().ToLowerInvariant()" data-type="@campo.Tipo"><td><strong class="field-name">@campo.Nome</strong><small style="display:block">@campo.Descricao</small></td><td><select class="column-select"><option value="">Não importar</option>@foreach(var h in Model.Cabecalhos){<option value="@h" selected="@(h==selected)">@h</option>}</select></td><td><span class="badge status"></span></td><td><span class="badge">@campo.Tipo</span></td><td class="observation">@(confidence>0 ? $"Detectado automaticamente ({confidence:P0})" : "Opcional")</td></tr>}
</tbody></table></div></orizon-card>
<orizon-card title="Pré-visualização — primeiras 20 linhas"><div class="preview-wrap"><table class="table preview-table"><thead><tr><th>Linha</th>@foreach(var c in Model.Campos){<th data-preview-field="@c.Chave" hidden>@c.Nome<small></small></th>}</tr></thead><tbody>@foreach(var row in Model.Amostra){<tr><td>@row.NumeroLinha</td>@foreach(var c in Model.Campos){<td data-preview-field="@c.Chave" data-values='@JsonSerializer.Serialize(row.Valores)' hidden></td>}</tr>}</tbody></table></div></orizon-card>
<div class="map-actions"><a class="btn btn-secondary" href="@Url.Action("Preview",new{id=Model.ImportacaoId,token=Model.TokenArquivo,aba=Model.AbaSelecionada})">← Voltar</a><button class="btn btn-primary" id="continueButton" disabled>Continuar para validação →</button></div>
<script>
const headers=@Html.Raw(JsonSerializer.Serialize(Model.Cabecalhos)); const sample=@Html.Raw(JsonSerializer.Serialize(Model.Amostra.Select(x=>x.Valores))); const rows=[...document.querySelectorAll('.map-row')]; const token=document.querySelector('input[name="__RequestVerificationToken"]').value;
const payload=()=>({nome:'',padrao:false,cabecalhos:headers,amostra:sample,mapeamentos:Object.fromEntries(rows.map(r=>[r.dataset.field,r.querySelector('select').value]).filter(x=>x[1]))});
function refresh(){const used=new Map();rows.forEach(r=>{const s=r.querySelector('select'),v=s.value;if(v)used.set(v,(used.get(v)||0)+1)});let missing=0,mapped=0,errors=0;rows.forEach(r=>{const v=r.querySelector('select').value,dup=v&&used.get(v)>1,status=r.querySelector('.status'),obs=r.querySelector('.observation');r.classList.toggle('error',!!dup||r.dataset.required==='true'&&!v);if(v)mapped++;if(r.dataset.required==='true'&&!v)missing++;if(dup){status.textContent='Conflito';status.className='badge status warn';obs.textContent='Coluna usada mais de uma vez';errors++}else if(v){status.textContent='Mapeado';status.className='badge status ok';if(!obs.textContent.startsWith('Detectado'))obs.textContent='Pronto para importar'}else{status.textContent=r.dataset.required==='true'?'Pendente':'Ignorado';status.className='badge status '+(r.dataset.required==='true'?'warn':'');if(r.dataset.required==='true')errors++}}
document.querySelectorAll('[data-preview-field]').forEach(cell=>{const field=cell.dataset.previewField,row=rows.find(x=>x.dataset.field===field),col=row.querySelector('select').value;cell.hidden=!col;if(cell.tagName==='TH')cell.querySelector('small').textContent=col;else{const value=col?(JSON.parse(cell.dataset.values)[col]??''):'';cell.textContent=value;cell.classList.toggle('empty',row.dataset.required==='true'&&!String(value).trim())}});const required=rows.filter(x=>x.dataset.required==='true').length,done=required-missing,pct=required?Math.round(done/required*100):100;document.querySelector('#progressText').textContent=pct+'%';document.querySelector('#progressBar').style.width=pct+'%';document.querySelector('#mappedCount').textContent=mapped;document.querySelector('#unusedCount').textContent=headers.length-used.size;document.querySelector('#missingCount').textContent=missing;document.querySelector('#continueButton').disabled=errors>0;const n=document.querySelector('#validationNotice');n.hidden=errors===0;n.className='notice error';n.textContent=errors?`${errors} erro(s) impedem a continuação. Corrija os campos destacados.`:''}
rows.forEach(r=>r.querySelector('select').addEventListener('change',refresh));refresh();
document.querySelector('#modelSelect').addEventListener('change',e=>location.href='@Url.Action("Mapeamento",new{id=Model.ImportacaoId,token=Model.TokenArquivo,aba=Model.AbaSelecionada})&modeloId='+e.target.value);
document.querySelector('#saveModel').addEventListener('click',async()=>{const nome=prompt('Nome do modelo:');if(!nome)return;const body=payload();body.nome=nome;body.padrao=confirm('Definir como modelo padrão?');const res=await fetch('@Url.Action("SalvarModelo")',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':token},body:JSON.stringify(body)});if(res.ok)location.reload();else alert('Não foi possível salvar o modelo.')});
document.querySelector('#deleteModel').addEventListener('click',async()=>{const id=document.querySelector('#modelSelect').value;if(!id||!confirm('Excluir este modelo?'))return;const res=await fetch('@Url.Action("ExcluirModelo")/'+id,{method:'POST',headers:{'RequestVerificationToken':token}});if(res.ok)location.href='@Url.Action("Mapeamento",new{id=Model.ImportacaoId,token=Model.TokenArquivo,aba=Model.AbaSelecionada})'});
document.querySelector('#continueButton').addEventListener('click',async()=>{const res=await fetch('@Url.Action("ValidarMapeamento")',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':token},body:JSON.stringify(payload())});const result=await res.json();if(!result.valido){alert(result.erros.map(x=>x.mensagem).join('\n'));refresh();return}alert('Mapeamento válido. A etapa de validação de produtos será implementada na próxima fase.')});
</script>

@model Orizon.Distribuidora.Web.Models.Account.LoginViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Entrar";
    ViewData["ApplicationName"] = "Distribuidora";
    var currentYear = DateTime.UtcNow.Year;
}

<section class="auth-shell" aria-labelledby="auth-title">
    <div class="auth-brand-panel">
        <div class="auth-brand-topline">
            <span class="auth-brand-mark" aria-hidden="true">
                <svg viewBox="0 0 32 32" role="img" focusable="false">
                    <path d="M16 3.5 27.5 10v12L16 28.5 4.5 22V10L16 3.5Z" />
                    <path d="M10.5 13.1 16 10l5.5 3.1v5.8L16 22l-5.5-3.1v-5.8Z" />
                </svg>
            </span>
            <span class="auth-brand-name">Orizon Distribuidora</span>
        </div>

        <div class="auth-brand-copy">
            <span class="auth-kicker">Gestao inteligente de produtos, precos e estoque</span>
            <h1 id="auth-title">Controle sua distribuidora com mais agilidade</h1>
            <p>
                Produtos, precos, estoque e operacoes em uma unica plataforma criada
                para equipes que trabalham com grandes volumes de dados.
            </p>
        </div>

        <ul class="auth-benefits" aria-label="Beneficios da plataforma">
            <li>
                <span aria-hidden="true">✓</span>
                Gestao rapida de milhares de produtos
            </li>
            <li>
                <span aria-hidden="true">✓</span>
                Atualizacao de precos com agilidade
            </li>
            <li>
                <span aria-hidden="true">✓</span>
                Estoque e movimentacoes centralizados
            </li>
            <li>
                <span aria-hidden="true">✓</span>
                Experiencia pensada para produtividade
            </li>
        </ul>

        <div class="auth-insight-grid" aria-hidden="true">
            <div class="auth-insight-card">
                <span>SKU</span>
                <strong>12.8k</strong>
                <small>produtos ativos</small>
            </div>
            <div class="auth-insight-card">
                <span>Preco</span>
                <strong>4 min</strong>
                <small>atualizacao media</small>
            </div>
            <div class="auth-insight-card auth-insight-card-wide">
                <span>Operacao</span>
                <strong>Centralizada</strong>
                <small>estoque, cadastros e auditoria no mesmo fluxo</small>
            </div>
        </div>
    </div>

    <div class="auth-form-panel">
        <section class="auth-card" aria-labelledby="auth-form-title">
            <div class="auth-card-header">
                <span class="auth-card-eyebrow">Acesso seguro</span>
                <h2 id="auth-form-title">Bem-vindo de volta</h2>
                <p>Acesse sua conta para continuar</p>
            </div>

            <form asp-controller="Account"
                  asp-action="Login"
                  method="post"
                  class="auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="Email">E-mail</label>
                    <input asp-for="Email"
                           class="auth-input"
                           autocomplete="username"
                           inputmode="email"
                           autofocus />
                    <span asp-validation-for="Email" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Password">Senha</label>
                    <div class="auth-password-wrap">
                        <input asp-for="Password"
                               class="auth-input auth-password-input"
                               autocomplete="current-password" />
                        <button type="button"
                                class="auth-password-toggle"
                                data-password-toggle
                                aria-label="Mostrar senha"
                                aria-pressed="false">
                            <svg class="auth-eye-open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M2.5 12s3.4-6 9.5-6 9.5 6 9.5 6-3.4 6-9.5 6-9.5-6-9.5-6Z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                            <svg class="auth-eye-closed" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="m4 4 16 16" />
                                <path d="M9.2 5.5A10.2 10.2 0 0 1 12 5c6.1 0 9.5 7 9.5 7a16 16 0 0 1-3 4.1" />
                                <path d="M14.8 18.5A10.2 10.2 0 0 1 12 19c-6.1 0-9.5-7-9.5-7a16 16 0 0 1 3-4.1" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="auth-field-error"></span>
                </div>

                <div class="auth-form-options">
                    <label class="auth-checkbox">
                        <input asp-for="RememberMe" />
                        <span>Lembrar-me</span>
                    </label>
                    <span class="auth-recovery-link" aria-disabled="true">Recuperar acesso</span>
                </div>

                <button type="submit" class="auth-submit">
                    <span>Entrar</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M5 12h13" />
                        <path d="m13 6 6 6-6 6" />
                    </svg>
                </button>
            </form>
        </section>

        <footer class="auth-footer">
            Orizon Distribuidora © @currentYear
        </footer>
    </div>
</section>

@section Scripts {
    <script src="~/js/auth-login.js" asp-append-version="true"></script>
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    var pageTitle = ViewData["Title"]?.ToString();
    var applicationName = ViewData["ApplicationName"]?.ToString() ?? "Orizon Distribuidora";
    var fullTitle = string.IsNullOrWhiteSpace(pageTitle)
        ? applicationName
        : $"{pageTitle} | {applicationName}";

    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var theme = ViewData["Theme"]?.ToString() ?? "light";
}

<!DOCTYPE html>
<html lang="pt-BR" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>@fullTitle</title>

    <meta name="application-name" content="@applicationName" />
    <meta name="request-verification-token" content="@requestToken" />

    <!-- Orizon UI -->
    <link rel="stylesheet"
          href="~/_content/Orizon.UI/css/orizon.css"
          asp-append-version="true" />

    <!-- Apenas estilos específicos do Distribuidora -->
    <link rel="stylesheet"
          href="~/css/admin-navigation.css"
          asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="orizon-admin-body">

    <a class="orizon-skip-link" href="#main-content">
        Ir para o conteúdo principal
    </a>

    <div class="orizon-admin-shell" data-admin-layout>

        <!-- Backdrop Mobile -->
        <div class="orizon-sidebar-backdrop"
             data-sidebar-backdrop
             aria-hidden="true">
        </div>

        <!-- Sidebar -->
        <aside id="admin-sidebar"
               class="orizon-admin-sidebar"
               data-sidebar
               aria-label="Menu principal">

            <partial name="_Sidebar" />

        </aside>

        <!-- Área Principal -->
        <div class="orizon-admin-main">

            <!-- Topbar -->
            <header class="orizon-admin-topbar">

                <partial name="_Topbar" />

            </header>

            <!-- Conteúdo -->
            <main id="main-content"
                  class="orizon-admin-content"
                  tabindex="-1">

                <partial name="_Breadcrumb" />

                <div class="orizon-admin-page">

                    @RenderBody()

                </div>

            </main>

            <!-- Rodapé -->
            <footer class="orizon-admin-footer">

                <partial name="_Footer" />

            </footer>

        </div>

    </div>

   <script src="~/_content/Orizon.UI/js/layout/admin-layout.js"
        asp-append-version="true"></script>

<script src="~/_content/Orizon.UI/js/layout/sidebar.js"
        asp-append-version="true"></script>

<script src="~/_content/Orizon.UI/js/layout/theme.js"
        asp-append-version="true"></script>

<script src="~/js/admin-navigation.js"
        asp-append-version="true"></script>

<script type="module"
        src="~/_content/Orizon.UI/js/orizon.js"
        asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>